// SUBJEKTÄ°F SKOR GÄ°RDÄ°LERÄ°
// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model SubjectiveInput {
  id         String   @id @default(uuid())
  entityId   String   @unique

  // KKB & Kredi Sicili (max 10 puan)
  kkbCategory       String   @default("orta")   // iyi | orta | kotu | cok_kotu
  activeDelayDays   Int      @default(0)         // 0=yok | 30=1-30gÃ¼n | 90=31-90gÃ¼n | 999=90+gÃ¼n
  checkProtest      Boolean  @default(false)
  enforcementFile   Boolean  @default(false)

  // Banka Ä°liÅŸkileri (max 10 puan)
  creditLimitUtilPct Float   @default(70)        // 0-100
  hasMultipleBanks   Boolean @default(false)
  avgMaturityMonths  Int     @default(6)         // 3 | 6 | 12 | 24 | 36

  // Kurumsal YapÄ± (max 5 puan)
  companyAgeYears    Int     @default(3)
  auditLevel         String  @default("ymm")    // yok | smmm | ymm | tam_tasdik | bagimsiz
  ownershipClarity   Boolean @default(true)

  // Uyum & Risk (max 5 puan)
  hasTaxDebt         Boolean @default(false)
  hasSgkDebt         Boolean @default(false)
  activeLawsuitCount Int     @default(0)

  updatedAt  DateTime @updatedAt

  entity     Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("subjective_inputs")
}

// ─────────────────────────────────────────────
// HESAP PLANI SATIR KAYITLARI
// ─────────────────────────────────────────────

model FinancialAccount {
  id           String   @id @default(cuid())
  analysisId   String
  analysis     Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  accountCode  String
  accountName  String
  amount       Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([analysisId])
  @@index([accountCode])
  @@map("financial_accounts")
}

