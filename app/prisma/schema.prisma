generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────
// KULLANICI & ABONELİK
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  fullName      String
  companyName   String?
  role          String   @default("USER")
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscription  Subscription?
  entities      Entity[]
  groups        Group[]
  analyses      Analysis[]
  tenzilatEntries TenzilatEntry[]
  auditLogs     TenzilatAuditLog[]

  @@map("users")
}

model Subscription {
  id              String   @id @default(uuid())
  userId          String   @unique
  plan            String   @default("DEMO")
  billingCycle    String   @default("MONTHLY")
  status          String   @default("ACTIVE")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean @default(false)
  iyzicoSubKey    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments        Payment[]

  @@map("subscriptions")
}

model Payment {
  id              String   @id @default(uuid())
  subscriptionId  String
  amount          Float
  currency        String   @default("TRY")
  status          String
  iyzicoPaymentId String?
  createdAt       DateTime @default(now())

  subscription    Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("payments")
}

// ─────────────────────────────────────────────
// ŞİRKET (ENTITY) & GRUP
// ─────────────────────────────────────────────

model Entity {
  id                   String   @id @default(uuid())
  userId               String
  name                 String
  taxNumber            String?
  sector               String?
  entityType           String   @default("STANDALONE")
  groupId              String?
  ownershipPct         Float?
  consolidationInclude Boolean  @default(true)
  weightBasis          String   @default("REVENUE")
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group               Group?   @relation(fields: [groupId], references: [id])
  financialData       FinancialData[]
  analyses            Analysis[]
  tenzilatEntries     TenzilatEntry[]
  icTransactionsSell  IcTransaction[] @relation("SellerEntity")
  icTransactionsBuy   IcTransaction[] @relation("BuyerEntity")

  @@map("entities")
}

model Group {
  id               String   @id @default(uuid())
  userId           String
  name             String
  baseCurrency     String   @default("TRY")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entities         Entity[]
  analyses         Analysis[]
  icTransactions   IcTransaction[]
  eliminationLogs  EliminationLog[]
  tenzilatEntries  TenzilatEntry[]

  @@map("groups")
}

// ─────────────────────────────────────────────
// FİNANSAL VERİ
// ─────────────────────────────────────────────

model FinancialData {
  id          String   @id @default(uuid())
  entityId    String
  year        Int
  period      String   @default("ANNUAL")
  source      String   @default("MANUAL")
  fileName    String?
  fileUrl     String?

  cash                    Float?
  shortTermInvestments    Float?
  tradeReceivables        Float?
  inventory               Float?
  otherCurrentAssets      Float?
  totalCurrentAssets      Float?

  tangibleAssets          Float?
  intangibleAssets        Float?
  longTermInvestments     Float?
  otherNonCurrentAssets   Float?
  totalNonCurrentAssets   Float?
  totalAssets             Float?

  shortTermFinancialDebt  Float?
  tradePayables           Float?
  otherCurrentLiabilities Float?
  totalCurrentLiabilities Float?

  longTermFinancialDebt      Float?
  otherNonCurrentLiabilities Float?
  totalNonCurrentLiabilities Float?

  paidInCapital              Float?
  retainedEarnings           Float?
  netProfitCurrentYear       Float?
  totalEquity                Float?
  totalLiabilitiesAndEquity  Float?

  revenue             Float?
  cogs                Float?
  grossProfit         Float?
  operatingExpenses   Float?
  ebit                Float?
  depreciation        Float?
  ebitda              Float?
  interestExpense     Float?
  otherIncome         Float?
  otherExpense        Float?
  ebt                 Float?
  taxExpense          Float?
  netProfit           Float?
  purchases           Float?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  entity              Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  analysis            Analysis?

  @@unique([entityId, year, period])
  @@map("financial_data")
}

// ─────────────────────────────────────────────
// ANALİZ & SKOR
// ─────────────────────────────────────────────

model Analysis {
  id                  String   @id @default(uuid())
  userId              String
  entityId            String?
  groupId             String?
  financialDataId     String?  @unique
  year                Int
  period              String   @default("ANNUAL")
  mode                String   @default("SOLO")

  finalScore          Float?
  finalRating         String?
  liquidityScore      Float?
  profitabilityScore  Float?
  leverageScore       Float?
  activityScore       Float?

  weightedScore       Float?
  safFactor           Float?
  icDependencyRatio   Float?
  hasCrossGuarantee   Boolean  @default(false)

  ratios              String?  // JSON string
  consolidatedFinancials String? // JSON string

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id])
  entity              Entity?  @relation(fields: [entityId], references: [id])
  group               Group?   @relation(fields: [groupId], references: [id])
  financialData       FinancialData? @relation(fields: [financialDataId], references: [id])
  tenzilatEntries     TenzilatEntry[]

  @@map("analyses")
}

// ─────────────────────────────────────────────
// GRUP İÇİ İŞLEM & ELİMİNASYON
// ─────────────────────────────────────────────

model IcTransaction {
  id              String   @id @default(uuid())
  groupId         String
  year            Int
  sellerEntityId  String
  buyerEntityId   String
  type            String
  amount          Float
  isMatched       Boolean  @default(false)
  eliminationApplied Boolean @default(false)
  materialityPct  Float?
  createdAt       DateTime @default(now())

  group           Group    @relation(fields: [groupId], references: [id])
  seller          Entity   @relation("SellerEntity", fields: [sellerEntityId], references: [id])
  buyer           Entity   @relation("BuyerEntity", fields: [buyerEntityId], references: [id])
  eliminationLog  EliminationLog?

  @@map("ic_transactions")
}

model EliminationLog {
  id                String   @id @default(uuid())
  groupId           String
  icTransactionId   String   @unique
  year              Int
  amountEliminated  Float
  ruleApplied       String
  materialityPct    Float?
  createdAt         DateTime @default(now())

  group             Group        @relation(fields: [groupId], references: [id])
  icTransaction     IcTransaction @relation(fields: [icTransactionId], references: [id])

  @@map("elimination_logs")
}

// ─────────────────────────────────────────────
// MANUEL TENZİLAT
// ─────────────────────────────────────────────

model TenzilatEntry {
  id               String   @id @default(uuid())
  userId           String
  entityId         String?
  groupId          String?
  analysisId       String?
  year             Int
  period           String   @default("ANNUAL")
  adjustmentType   String
  adjustmentAmount Float
  description      String
  scope            String
  isActive         Boolean  @default(true)
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id])
  entity           Entity?  @relation(fields: [entityId], references: [id])
  group            Group?   @relation(fields: [groupId], references: [id])
  analysis         Analysis? @relation(fields: [analysisId], references: [id])
  auditLogs        TenzilatAuditLog[]

  @@map("tenzilat_entries")
}

model TenzilatAuditLog {
  id             String   @id @default(uuid())
  entryId        String
  userId         String
  action         String
  fieldChanged   String?
  oldValue       String?
  newValue       String?
  timestamp      DateTime @default(now())
  ipAddress      String?

  entry          TenzilatEntry @relation(fields: [entryId], references: [id])
  user           User          @relation(fields: [userId], references: [id])

  @@map("tenzilat_audit_logs")
}
