# Veritabanı (Hetzner sunucusunda PostgreSQL)
DATABASE_URL="postgresql://finrate_user:SIFRE@SUNUCU_IP:5432/finrate_db"

# Auth
JWT_SECRET="cok-gizli-bir-anahtar-buraya-yaz"
JWT_EXPIRES_IN="7d"
NEXTAUTH_SECRET="baska-bir-gizli-anahtar"
NEXTAUTH_URL="https://finrate.com"

# iyzico Ödeme
IYZICO_API_KEY="sandbox-api-key"
IYZICO_SECRET_KEY="sandbox-secret-key"
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# Dosya yükleme (sunucuda lokal storage)
UPLOAD_DIR="/var/finrate/uploads"
MAX_FILE_SIZE_MB=10
